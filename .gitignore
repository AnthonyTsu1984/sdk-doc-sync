node_modules/
.DS_Store
.env
.venv/

# Run-local artifacts and one-off scripts. SDK sync runs belong under
# tmp/sdk-doc-sync-runs/<language>-<track>/<run-id>/ and must never be tracked.
scripts/_tmp_*
tmp/

# Local doc agent runtime state
.claude/agent-team/config.json
.claude/agent-team/state/*.json

# SDK update worktrees
.worktrees/

# SDK source repos (cloned externally)
repos/*
!repos/.gitkeep
