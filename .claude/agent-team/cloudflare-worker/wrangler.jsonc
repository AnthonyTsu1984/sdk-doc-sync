{
  "$schema": "../../../node_modules/wrangler/config-schema.json",
  "name": "ztrans-doc-agent-webhook",
  "main": "src/index.mjs",
  "compatibility_date": "2026-07-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "FEISHU_HOST": "https://open.feishu.cn",
    "DOC_AGENT_WEBHOOK_PATH": "/feishu/events"
  },
  "kv_namespaces": [
    {
      "binding": "DECISIONS",
      "id": "3ef73ba233394f0b8398a6e8760479c3"
    }
  ]
}
